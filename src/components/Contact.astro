---
const serviceOptions = [
  'Selecciona un servicio',
  'Construcción en Edificaciones',
  'Servicios Generales',
  'Elaboración de Expedientes Técnicos',
  'Supervisión y Gerencia de Proyectos',
  'Levantamiento Topográfico',
  'Capacitación Inhouse (Gestión y Lean Construction)',
  'Otro / Consulta General',
];

const contactInfo = [
  {
    icon: 'email',
    label: 'Correo Electrónico',
    value: 'contacto@arynsa.com.pe',
    link: 'mailto:contacto@arynsa.com.pe',
  },
  {
    icon: 'phone',
    label: 'Teléfono / WhatsApp',
    value: '+51 XXX XXX XXX',
    link: 'tel:+51XXXXXXXXX',
  },
  {
    icon: 'location',
    label: 'Dirección',
    value: 'Lima, Perú',
    link: 'https://maps.google.com',
  },
  {
    icon: 'clock',
    label: 'Horario de Atención',
    value: 'Lunes a Viernes, 08:00 – 18:00',
    link: null,
  },
];
---

<section class="contact section" id="contacto" aria-label="Contacto">
  <div class="container">
    <!-- Header -->
    <div class="contact-header">
      <p class="section-label reveal">Contáctenos</p>
      <h2 class="section-title reveal delay-100">
        Hablemos de su <span>Próximo Proyecto</span>
      </h2>
      <p class="section-subtitle reveal delay-200">
        Estamos listos para escucharte y ofrecerte la solución más adecuada. Completa el formulario
        o escríbenos directamente, nuestro equipo te responderá en menos de 24 horas.
      </p>
    </div>

    <div class="contact-grid">
      <!-- Left: Contact Info -->
      <div class="contact-info reveal-left">
        <div class="contact-info__card">
          <div class="contact-info__pattern" aria-hidden="true"></div>

          <h3 class="contact-info__heading">Información de Contacto</h3>
          <p class="contact-info__subtext">
            Cuéntanos tu proyecto y te brindaremos una propuesta personalizada sin compromiso.
          </p>

          <ul class="contact-info__list" role="list">
            {contactInfo.map((item) => (
              <li class="contact-info__item">
                <div class="contact-info__icon" aria-hidden="true">
                  {item.icon === 'email' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                  )}
                  {item.icon === 'phone' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.23h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  )}
                  {item.icon === 'location' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  )}
                  {item.icon === 'clock' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                  )}
                </div>
                <div>
                  <p class="contact-info__item-label">{item.label}</p>
                  {item.link ? (
                    <a href={item.link} class="contact-info__item-value contact-info__link">{item.value}</a>
                  ) : (
                    <p class="contact-info__item-value">{item.value}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>

          <!-- Social/Trust signals -->
          <div class="contact-trust">
            <p class="contact-trust__label">Confían en nosotros</p>
            <div class="contact-trust__items">
              {['Sector Público', 'Sector Privado', 'Obras Civiles', 'Minería'].map((t) => (
                <span class="contact-trust__tag">{t}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="contact-form-wrap reveal-right">
        <form
          class="contact-form"
          id="contact-form"
          novalidate
          aria-label="Formulario de contacto"
        >
          <div class="form-row">
            <!-- Name -->
            <div class="form-group">
              <label for="contact-name" class="form-label">
                Nombre completo <span class="form-required" aria-hidden="true">*</span>
              </label>
              <div class="form-input-wrap">
                <svg class="form-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  class="form-input"
                  placeholder="Ej: Juan Pérez García"
                  required
                  autocomplete="name"
                  aria-required="true"
                />
              </div>
              <span class="form-error" id="name-error" role="alert"></span>
            </div>

            <!-- Email -->
            <div class="form-group">
              <label for="contact-email" class="form-label">
                Correo electrónico <span class="form-required" aria-hidden="true">*</span>
              </label>
              <div class="form-input-wrap">
                <svg class="form-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  class="form-input"
                  placeholder="correo@empresa.com"
                  required
                  autocomplete="email"
                  aria-required="true"
                />
              </div>
              <span class="form-error" id="email-error" role="alert"></span>
            </div>
          </div>

          <div class="form-row">
            <!-- Phone -->
            <div class="form-group">
              <label for="contact-phone" class="form-label">
                Teléfono / WhatsApp
              </label>
              <div class="form-input-wrap">
                <svg class="form-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.23h3a2 2 0 0 1 2 1.72c.118.61.2 1.23.25 1.84.114.912.25 1.75.41 2.5"/>
                  <path d="m16.72 17.28 1.27-1.27a2 2 0 0 1 2.11-.45c.9.36 1.83.63 2.77.81A2 2 0 0 1 24.5 18v2.5"/>
                </svg>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  class="form-input"
                  placeholder="+51 XXX XXX XXX"
                  autocomplete="tel"
                />
              </div>
            </div>

            <!-- Service -->
            <div class="form-group">
              <label for="contact-service" class="form-label">
                Servicio de interés <span class="form-required" aria-hidden="true">*</span>
              </label>
              <div class="form-input-wrap form-select-wrap">
                <svg class="form-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                </svg>
                <select
                  id="contact-service"
                  name="service"
                  class="form-input form-select"
                  required
                  aria-required="true"
                >
                  {serviceOptions.map((opt, i) => (
                    <option value={i === 0 ? '' : opt} disabled={i === 0} selected={i === 0}>
                      {opt}
                    </option>
                  ))}
                </select>
                <svg class="form-select-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
              <span class="form-error" id="service-error" role="alert"></span>
            </div>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="contact-message" class="form-label">
              Mensaje <span class="form-required" aria-hidden="true">*</span>
            </label>
            <div class="form-input-wrap form-textarea-wrap">
              <svg class="form-input-icon form-input-icon--textarea" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
              <textarea
                id="contact-message"
                name="message"
                class="form-input form-textarea"
                placeholder="Cuéntanos sobre tu proyecto: ubicación, tipo de obra, área aproximada, plazos estimados..."
                rows="5"
                required
                aria-required="true"
              ></textarea>
            </div>
            <span class="form-error" id="message-error" role="alert"></span>
          </div>

          <!-- Privacy note -->
          <p class="form-privacy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Tu información es confidencial y nunca será compartida con terceros.
          </p>

          <!-- Submit -->
          <button type="submit" class="form-submit" id="form-submit-btn">
            <span class="form-submit__text">Enviar mensaje</span>
            <span class="form-submit__loading" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="spin" aria-hidden="true">
                <polyline points="23 4 23 10 17 10"/>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
              </svg>
              Enviando...
            </span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>

          <!-- Success/Error messages -->
          <div class="form-success" id="form-success" role="status" aria-live="polite" style="display:none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <div>
              <strong>¡Mensaje enviado con éxito!</strong>
              <p>Te responderemos en menos de 24 horas hábiles.</p>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-light);
    position: relative;
    overflow: hidden;
  }

  .contact::before {
    content: '';
    position: absolute;
    bottom: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(27, 42, 74, 0.04) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  /* Header */
  .contact-header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .contact-header .section-subtitle {
    margin-inline: auto;
  }

  /* Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  /* Info Card */
  .contact-info__card {
    background: var(--color-primary);
    border-radius: var(--radius-2xl);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  .contact-info__pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 25px 25px;
    pointer-events: none;
  }

  .contact-info__heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .contact-info__subtext {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  .contact-info__list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
    position: relative;
    z-index: 1;
  }

  .contact-info__item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-info__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: rgba(200, 168, 75, 0.12);
    border: 1px solid rgba(200, 168, 75, 0.25);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    transition: background-color var(--transition-base);
  }

  .contact-info__item:hover .contact-info__icon {
    background: rgba(200, 168, 75, 0.2);
  }

  .contact-info__item-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }

  .contact-info__item-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }

  .contact-info__link {
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .contact-info__link:hover {
    color: var(--color-accent);
  }

  /* Trust */
  .contact-trust {
    position: relative;
    z-index: 1;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .contact-trust__label {
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .contact-trust__items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .contact-trust__tag {
    padding: 0.3rem 0.75rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.04em;
  }

  /* Form */
  .contact-form-wrap {
    background: var(--color-white);
    border-radius: var(--radius-2xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }

  .form-required {
    color: var(--color-accent-dark);
  }

  .form-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .form-input-icon {
    position: absolute;
    left: 0.875rem;
    color: var(--color-text-muted);
    pointer-events: none;
    z-index: 1;
    flex-shrink: 0;
    transition: color var(--transition-base);
  }

  .form-input-icon--textarea {
    top: 0.875rem;
    align-self: flex-start;
  }

  .form-input {
    width: 100%;
    padding: 0.75rem 0.875rem 0.75rem 2.75rem;
    font-size: 0.9rem;
    color: var(--color-text-dark);
    background: var(--color-light);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-base), box-shadow var(--transition-base), background-color var(--transition-base);
    appearance: none;
    -webkit-appearance: none;
  }

  .form-input::placeholder {
    color: var(--color-text-light);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: var(--color-white);
    box-shadow: 0 0 0 3px rgba(200, 168, 75, 0.12);
  }

  .form-input:focus + .form-input-icon,
  .form-input-wrap:focus-within .form-input-icon {
    color: var(--color-accent);
  }

  .form-input.error {
    border-color: var(--color-error);
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  /* Select */
  .form-select-wrap {
    position: relative;
  }

  .form-select {
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .form-select option {
    background: var(--color-white);
    color: var(--color-text-dark);
  }

  .form-select-arrow {
    position: absolute;
    right: 0.875rem;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  /* Textarea */
  .form-textarea-wrap {
    align-items: flex-start;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
    padding-top: 0.875rem;
    line-height: 1.6;
  }

  /* Errors */
  .form-error {
    font-size: 0.75rem;
    color: var(--color-error);
    font-weight: 500;
    min-height: 1.1rem;
    display: block;
  }

  /* Privacy */
  .form-privacy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background: var(--color-light);
    padding: 0.625rem 1rem;
    border-radius: var(--radius-md);
  }

  .form-privacy svg {
    flex-shrink: 0;
    color: var(--color-accent-dark);
  }

  /* Submit button */
  .form-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: 100%;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-base);
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
  }

  .form-submit::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 0%, rgba(200,168,75,0.1) 100%);
  }

  .form-submit:hover {
    background: var(--color-secondary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-accent);
  }

  .form-submit:active {
    transform: translateY(0);
  }

  .form-submit__loading {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  .form-submit.loading .form-submit__text,
  .form-submit.loading > svg:last-child {
    display: none;
  }

  .form-submit.loading .form-submit__loading {
    display: flex;
  }

  .spin {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Success message */
  .form-success {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: rgba(16, 185, 129, 0.08);
    border: 1.5px solid rgba(16, 185, 129, 0.25);
    border-radius: var(--radius-lg);
    color: var(--color-text-dark);
    margin-top: 0.5rem;
  }

  .form-success svg {
    flex-shrink: 0;
    color: var(--color-success);
    margin-top: 2px;
  }

  .form-success strong {
    display: block;
    font-size: 0.95rem;
    color: #065f46;
    margin-bottom: 0.2rem;
  }

  .form-success p {
    font-size: 0.85rem;
    color: #047857;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrap {
      padding: 1.5rem;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement | null;
  const successMsg = document.getElementById('form-success') as HTMLElement | null;

  function showError(fieldId: string, message: string) {
    const errorEl = document.getElementById(`${fieldId}-error`);
    const input = document.getElementById(`contact-${fieldId}`);
    if (errorEl) errorEl.textContent = message;
    if (input) input.classList.add('error');
  }

  function clearError(fieldId: string) {
    const errorEl = document.getElementById(`${fieldId}-error`);
    const input = document.getElementById(`contact-${fieldId}`);
    if (errorEl) errorEl.textContent = '';
    if (input) input.classList.remove('error');
  }

  function validateEmail(email: string) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  // Real-time validation
  ['name', 'email', 'service', 'message'].forEach((fieldId) => {
    const input = document.getElementById(`contact-${fieldId}`);
    input?.addEventListener('input', () => clearError(fieldId));
    input?.addEventListener('blur', () => {
      const val = (input as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement).value.trim();
      if (!val) {
        const labels: Record<string, string> = {
          name: 'El nombre es requerido',
          email: 'El correo es requerido',
          service: 'Selecciona un servicio',
          message: 'El mensaje es requerido',
        };
        showError(fieldId, labels[fieldId] || 'Campo requerido');
      } else if (fieldId === 'email' && !validateEmail(val)) {
        showError('email', 'Ingresa un correo válido');
      }
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    const name = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
    const service = (document.getElementById('contact-service') as HTMLSelectElement).value.trim();
    const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();

    let hasErrors = false;

    if (!name) { showError('name', 'El nombre es requerido'); hasErrors = true; }
    else clearError('name');

    if (!email) { showError('email', 'El correo es requerido'); hasErrors = true; }
    else if (!validateEmail(email)) { showError('email', 'Ingresa un correo válido'); hasErrors = true; }
    else clearError('email');

    if (!service) { showError('service', 'Selecciona un servicio'); hasErrors = true; }
    else clearError('service');

    if (!message) { showError('message', 'El mensaje es requerido'); hasErrors = true; }
    else clearError('message');

    if (hasErrors) return;

    // Simulate form submission
    submitBtn.classList.add('loading');
    submitBtn.disabled = true;

    try {
      await new Promise((resolve) => setTimeout(resolve, 1800));
      if (successMsg) {
        successMsg.style.display = 'flex';
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      form.reset();
    } catch {
      // Handle error
    } finally {
      submitBtn.classList.remove('loading');
      submitBtn.disabled = false;
    }
  });
</script>
