---
const currentYear = new Date().getFullYear();

const serviceLinks = [
  { label: 'Construcción en Edificaciones', href: '#servicios' },
  { label: 'Servicios Generales', href: '#servicios' },
  { label: 'Expedientes Técnicos', href: '#servicios' },
  { label: 'Supervisión de Proyectos', href: '#servicios' },
  { label: 'Levantamiento Topográfico', href: '#servicios' },
  { label: 'Capacitación Lean Construction', href: '#servicios' },
];

const companyLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Por Qué Nosotros', href: '#por-que-nosotros' },
  { label: 'Estadísticas', href: '#estadisticas' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="footer" role="contentinfo">
  <!-- Top red-accent line -->
  <div class="footer-top-line" aria-hidden="true"></div>

  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Column 1: Brand -->
        <div class="footer-brand">
          <a href="#inicio" class="footer-logo" aria-label="ARYNSA - Inicio">
            <span class="footer-logo__icon" aria-hidden="true">
              <!-- ARYNSA Chevron Logo Mark -->
              <svg width="50" height="40" viewBox="0 0 52 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M0 44 L17 44 L28 2 L11 2 Z" fill="#C8A84B"/>
                <path d="M24 2 L41 2 L52 44 L35 44 Z" fill="white" fill-opacity="0.85"/>
              </svg>
            </span>
            <div class="footer-logo__text">
              <span class="footer-logo__name">ARYNSA</span>
              <span class="footer-logo__tagline">Ingeniería y Construcción</span>
            </div>
          </a>

          <p class="footer-brand__desc">
            Empresa peruana líder en construcción de edificaciones, consultoría técnica y gestión integral
            de proyectos. Transformamos ideas en obras de calidad que perduran en el tiempo.
          </p>

          <!-- Certifications/badges -->
          <div class="footer-badges">
            {['RNP', 'OSCE', 'PMI', 'BIM', 'Lean'].map((b) => (
              <span class="footer-badge">{b}</span>
            ))}
          </div>

          <!-- Contact quick links -->
          <div class="footer-quick-contact">
            <a href="mailto:contacto@arynsa.com.pe" class="footer-quick-link" aria-label="Enviar email a ARYNSA">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              contacto@arynsa.com.pe
            </a>
            <a href="tel:+51XXXXXXXXX" class="footer-quick-link" aria-label="Llamar a ARYNSA">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.23h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              +51 XXX XXX XXX
            </a>
            <a href="#" class="footer-quick-link" aria-label="Ver ubicación en el mapa">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Lima, Perú
            </a>
          </div>
        </div>

        <!-- Column 2: Services -->
        <div class="footer-col">
          <h3 class="footer-col__title">Servicios</h3>
          <ul class="footer-links" role="list">
            {serviceLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Company -->
        <div class="footer-col">
          <h3 class="footer-col__title">Empresa</h3>
          <ul class="footer-links" role="list">
            {companyLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 4: Newsletter/CTA -->
        <div class="footer-col">
          <h3 class="footer-col__title">¿Tienes un Proyecto?</h3>
          <p class="footer-col__text">
            Contáctanos hoy mismo y recibe una consulta gratuita. Nuestro equipo está listo para ayudarte.
          </p>

          <a href="#contacto" class="footer-cta-btn">
            Solicitar Consulta Gratuita
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>

          <!-- Hours -->
          <div class="footer-hours">
            <div class="footer-hours__header">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>Horario de Atención</span>
            </div>
            <p>Lunes – Viernes: 08:00 – 18:00</p>
            <p>Sábados: 09:00 – 13:00</p>
          </div>

          <!-- Emergency contact note -->
          <div class="footer-emergency">
            <span class="footer-emergency__dot" aria-hidden="true"></span>
            <p>Servicio de emergencias disponible 24/7 para obras en ejecución</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p class="footer-copyright">
        &copy; {currentYear} <strong>ARYNSA</strong> &ndash; Ingeniería y Construcción S.A.C. Todos los derechos reservados.
      </p>
      <div class="footer-legal">
        <a href="/politica-privacidad" class="footer-legal-link">Política de Privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="/terminos" class="footer-legal-link">Términos de Uso</a>
        <span aria-hidden="true">·</span>
        <a href="/sitemap-index.xml" class="footer-legal-link">Sitemap</a>
      </div>
      <p class="footer-location">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Lima, Perú &mdash; RUC: XXXXXXXXXXX
      </p>
    </div>
  </div>

  <!-- Back to top button -->
  <button class="back-to-top" id="back-to-top" aria-label="Volver al inicio de la página">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>
</footer>

<style>
  .footer {
    background: var(--color-primary-dark);
    position: relative;
    color: rgba(255,255,255,0.7);
  }

  /* Top accent line */
  .footer-top-line {
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--color-accent), var(--color-accent-light), var(--color-accent), transparent);
  }

  /* Main footer */
  .footer-main {
    padding-block: clamp(3rem, 8vw, 5rem);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: clamp(2rem, 4vw, 3.5rem);
  }

  /* Brand column */
  .footer-brand {}

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .footer-logo__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .footer-logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .footer-logo__name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 900;
    color: #C8A84B;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-logo__tagline {
    font-size: 0.6rem;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 1px;
  }

  .footer-brand__desc {
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1.25rem;
    max-width: 320px;
  }

  /* Badges */
  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .footer-badge {
    padding: 0.25rem 0.625rem;
    background: rgba(200, 168, 75, 0.1);
    border: 1px solid rgba(200, 168, 75, 0.25);
    border-radius: var(--radius-full);
    font-size: 0.65rem;
    font-weight: 700;
    color: #C8A84B;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Quick contact */
  .footer-quick-contact {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-quick-link:hover {
    color: #C8A84B;
  }

  .footer-quick-link svg {
    flex-shrink: 0;
    color: #C8A84B;
    opacity: 0.8;
  }

  /* Footer columns */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-col__title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 0;
  }

  .footer-col__text {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
  }

  /* Links */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color var(--transition-base), gap var(--transition-base);
    line-height: 1.4;
  }

  .footer-link svg {
    flex-shrink: 0;
    color: #C8A84B;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .footer-link:hover {
    color: #C8A84B;
    gap: 0.625rem;
  }

  .footer-link:hover svg {
    opacity: 1;
  }

  /* CTA button in footer */
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all var(--transition-base);
    width: fit-content;
  }

  .footer-cta-btn:hover {
    background: var(--color-accent-light);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(200,168,75,0.3);
  }

  /* Hours */
  .footer-hours {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  .footer-hours__header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 700;
    color: rgba(255,255,255,0.65);
    margin-bottom: 0.25rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .footer-hours__header svg {
    color: #C8A84B;
  }

  /* Emergency note */
  .footer-emergency {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(200, 168, 75, 0.06);
    border-left: 2px solid rgba(200, 168, 75, 0.4);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .footer-emergency__dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    background: #C8A84B;
    border-radius: 50%;
    margin-top: 4px;
    animation: pulse 2s ease infinite;
  }

  .footer-emergency p {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  /* Bottom bar */
  .footer-bottom {
    padding-block: 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
  }

  .footer-copyright strong {
    color: rgba(255,255,255,0.6);
    font-weight: 700;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.25);
  }

  .footer-legal-link {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .footer-legal-link:hover {
    color: #ffffff;
  }

  .footer-location {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
  }

  .footer-location svg {
    color: rgba(255, 255, 255, 0.4);
    opacity: 1;
  }

  /* Back to top */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    color: #C8A84B;
    border: 2px solid rgba(200, 168, 75, 0.3);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 99;
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-lg);
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .back-to-top:hover {
    background: var(--color-accent);
    color: var(--color-primary);
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(200,168,75,0.4);
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-brand__desc {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer-bottom__inner {
      flex-direction: column;
      text-align: center;
    }

    .back-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 42px;
      height: 42px;
    }
  }
</style>

<script>
  const backToTopBtn = document.getElementById('back-to-top');

  window.addEventListener('scroll', () => {
    if (!backToTopBtn) return;
    if (window.scrollY > 400) {
      backToTopBtn.classList.add('visible');
    } else {
      backToTopBtn.classList.remove('visible');
    }
  }, { passive: true });

  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
