---
const services = [
  {
    id: 'edificaciones',
    title: 'Construcción en Edificaciones',
    description:
      'Ejecutamos proyectos de construcción de edificaciones residenciales, comerciales e industriales con los más altos estándares técnicos y de seguridad, asegurando calidad en cada etapa de la obra.',
    icon: 'building',
    tag: 'Construcción',
  },
  {
    id: 'servicios-generales',
    title: 'Servicios Generales',
    description:
      'Ofrecemos una amplia gama de servicios de mantenimiento, remodelación, instalaciones y trabajos especializados para satisfacer todas las necesidades de construcción y mantenimiento de su empresa.',
    icon: 'tools',
    tag: 'Mantenimiento',
  },
  {
    id: 'expedientes-tecnicos',
    title: 'Elaboración de Expedientes Técnicos',
    description:
      'Desarrollamos expedientes técnicos completos y detallados incluyendo estudios, memorias descriptivas, especificaciones técnicas, metrados, presupuestos y cronogramas conforme a normativa vigente.',
    icon: 'document',
    tag: 'Consultoría',
  },
  {
    id: 'supervision',
    title: 'Supervisión y Gerencia de Proyectos',
    description:
      'Brindamos servicios de supervisión técnica y gerencia integral de proyectos, garantizando el cumplimiento de plazos, presupuestos y estándares de calidad en cada fase del proyecto.',
    icon: 'chart',
    tag: 'Gestión',
  },
  {
    id: 'topografia',
    title: 'Levantamiento Topográfico',
    description:
      'Realizamos levantamientos topográficos de precisión con equipos de última generación, proporcionando datos cartográficos confiables para el diseño y ejecución de obras civiles.',
    icon: 'map',
    tag: 'Topografía',
  },
  {
    id: 'capacitacion',
    title: 'Capacitación Inhouse en Gestión y Lean',
    description:
      'Impartimos programas de capacitación especializada en gestión de proyectos y Lean Construction directamente en las instalaciones de su empresa, adaptando el contenido a su realidad operativa.',
    icon: 'education',
    tag: 'Formación',
  },
];
---

<section class="services section" id="servicios" aria-label="Nuestros Servicios">
  <!-- Background decoration -->
  <div class="services-bg" aria-hidden="true">
    <div class="services-bg__shape"></div>
  </div>

  <div class="container">
    <!-- Header -->
    <div class="services-header">
      <p class="section-label reveal">Nuestros Servicios</p>
      <h2 class="section-title reveal delay-100">
        Soluciones Integrales para<br />
        cada <span>Desafío</span>
      </h2>
      <p class="section-subtitle reveal delay-200">
        Ofrecemos un portafolio completo de servicios de construcción y consultoría, diseñados para
        acompañarte en cada etapa de tu proyecto con la mayor precisión técnica.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="services-grid">
      {services.map((service, index) => (
        <article
          class={`service-card reveal delay-${Math.min(index * 100 + 100, 600)}`}
          aria-label={service.title}
        >
          <div class="service-card__top">
            <div class="service-card__icon-wrap" aria-hidden="true">
              {service.icon === 'building' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                  <line x1="8" y1="21" x2="16" y2="21"/>
                  <line x1="12" y1="17" x2="12" y2="21"/>
                  <path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M6 12h.01M10 12h.01M14 12h.01M18 12h.01"/>
                </svg>
              )}
              {service.icon === 'tools' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
              )}
              {service.icon === 'document' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              )}
              {service.icon === 'chart' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                  <line x1="2" y1="20" x2="22" y2="20"/>
                </svg>
              )}
              {service.icon === 'map' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
                  <line x1="9" y1="3" x2="9" y2="18"/>
                  <line x1="15" y1="6" x2="15" y2="21"/>
                </svg>
              )}
              {service.icon === 'education' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                  <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
              )}
            </div>
            <span class="service-card__tag">{service.tag}</span>
          </div>

          <div class="service-card__body">
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.description}</p>
          </div>

          <div class="service-card__footer">
            <a href="#contacto" class="service-card__cta" aria-label={`Solicitar información sobre ${service.title}`}>
              Solicitar información
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>

          <!-- Gold corner accent -->
          <div class="service-card__accent" aria-hidden="true"></div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="services-cta reveal">
      <p>¿Tienes un proyecto en mente? Hablemos sobre cómo podemos ayudarte.</p>
      <a href="#contacto" class="btn-primary">
        Iniciar mi proyecto
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-light);
    position: relative;
    overflow: hidden;
  }

  .services-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .services-bg__shape {
    position: absolute;
    top: -80px;
    left: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(27, 42, 74, 0.05) 0%, transparent 70%);
    border-radius: 50%;
  }

  /* Header */
  .services-header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .services-header .section-subtitle {
    margin-inline: auto;
  }

  /* Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* Service Card */
  .service-card {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-slow), box-shadow var(--transition-slow), border-color var(--transition-slow);
    cursor: default;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-accent);
  }

  .service-card:hover .service-card__accent {
    opacity: 1;
    transform: scale(1.1);
  }

  .service-card:hover .service-card__icon-wrap {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  .service-card:hover .service-card__title {
    color: var(--color-primary);
  }

  /* Card top */
  .service-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .service-card__icon-wrap {
    width: 60px;
    height: 60px;
    background: var(--color-light);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .service-card__tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(200, 168, 75, 0.1);
    border: 1px solid rgba(200, 168, 75, 0.25);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  /* Card body */
  .service-card__body {
    flex: 1;
  }

  .service-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.625rem;
    line-height: 1.3;
    transition: color var(--transition-base);
  }

  .service-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  /* Card footer */
  .service-card__footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-light);
  }

  .service-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.825rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .service-card:hover .service-card__cta {
    color: var(--color-accent-dark);
    gap: 0.75rem;
  }

  /* Gold corner accent */
  .service-card__accent {
    position: absolute;
    bottom: -30px;
    right: -30px;
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(200, 168, 75, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    opacity: 0;
    transition: opacity var(--transition-slow), transform var(--transition-slow);
    pointer-events: none;
  }

  /* Bottom CTA */
  .services-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 3vw, 2rem);
    flex-wrap: wrap;
    padding: 2.5rem 2rem;
    background: var(--color-primary);
    border-radius: var(--radius-2xl);
    text-align: center;
  }

  .services-cta p {
    font-size: 1.1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .services-cta {
      flex-direction: column;
    }
  }
</style>
